{
  "name": "vscode-sql-helper",
  "displayName": "SQL Helper",
  "description": "VS Code extension with Vue app UI and Rust SQL analyzer.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "GPL-2.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/RapboyGao/vscode-sql-helper.git"
  },
  "homepage": "https://github.com/RapboyGao/vscode-sql-helper",
  "bugs": {
    "url": "https://github.com/RapboyGao/vscode-sql-helper/issues"
  },
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sqlHelper.openAnalyzer",
        "title": "SQL Helper: Open Analyzer"
      },
      {
        "command": "sqlHelper.addConnection",
        "title": "SQL Helper: Add Connection"
      },
      {
        "command": "sqlHelper.previewTable",
        "title": "SQL Helper: Preview SQLite Table"
      },
      {
        "command": "sqlHelper.previewQuery",
        "title": "SQL Helper: Preview Current SQL Query"
      },
      {
        "command": "sqlHelper.explainQuery",
        "title": "SQL Helper: Explain Current SQL Query"
      },
      {
        "command": "sqlHelper.refreshExplorer",
        "title": "SQL Helper: Refresh Explorer"
      },
      {
        "command": "sqlHelper.deleteProfileNode",
        "title": "SQL Helper: Remove Database Record"
      },
      {
        "command": "sqlHelper.addTableNode",
        "title": "SQL Helper: Add Table"
      },
      {
        "command": "sqlHelper.renameTableNode",
        "title": "SQL Helper: Rename Table"
      },
      {
        "command": "sqlHelper.deleteTableNode",
        "title": "SQL Helper: Delete Table"
      },
      {
        "command": "sqlHelper.exportDatabaseNode",
        "title": "SQL Helper: Export Database"
      },
      {
        "command": "sqlHelper.exportTableNode",
        "title": "SQL Helper: Export Table"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "sqlHelper.deleteProfileNode",
          "when": "view == sqlHelper.explorerView && viewItem == sqlHelper.profile",
          "group": "modification@2"
        },
        {
          "command": "sqlHelper.addTableNode",
          "when": "view == sqlHelper.explorerView && viewItem == sqlHelper.profile",
          "group": "modification"
        },
        {
          "command": "sqlHelper.exportDatabaseNode",
          "when": "view == sqlHelper.explorerView && viewItem == sqlHelper.profile",
          "group": "export"
        },
        {
          "command": "sqlHelper.renameTableNode",
          "when": "view == sqlHelper.explorerView && viewItem == sqlHelper.table",
          "group": "modification"
        },
        {
          "command": "sqlHelper.deleteTableNode",
          "when": "view == sqlHelper.explorerView && viewItem == sqlHelper.table",
          "group": "modification@2"
        },
        {
          "command": "sqlHelper.exportTableNode",
          "when": "view == sqlHelper.explorerView && viewItem == sqlHelper.table",
          "group": "export"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sqlHelper",
          "title": "SQL Helper",
          "icon": "assets/sql-helper.svg"
        }
      ]
    },
    "views": {
      "sqlHelper": [
        {
          "id": "sqlHelper.explorerView",
          "name": "Explorer",
          "icon": "assets/sql-helper.svg"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "sqlHelper.sqliteViewer",
        "displayName": "SQL Helper SQLite Viewer",
        "selector": [
          {
            "filenamePattern": "*.sqlite"
          },
          {
            "filenamePattern": "*.sqlite3"
          },
          {
            "filenamePattern": "*.db"
          },
          {
            "filenamePattern": "*.db3"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "clean": "bash scripts/clean.sh",
    "build": "bash scripts/build.sh",
    "build:vsix": "bash scripts/build-vsix.sh",
    "download:bins": "bash scripts/download-platform-bins.sh",
    "build:extension": "bash scripts/build-extension.sh",
    "build:webview": "bash scripts/build-webview.sh",
    "build:rust": "bash scripts/build-rust.sh",
    "dev:webview": "bash scripts/dev-webview.sh",
    "watch:extension": "bash scripts/watch-extension.sh",
    "check": "bash scripts/check.sh",
    "package": "bash scripts/package.sh"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "esbuild": "^0.25.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vue": "^3.5.13"
  },
  "dependencies": {
    "node-sql-parser": "^5.4.0",
    "xlsx": "^0.18.5"
  }
}
