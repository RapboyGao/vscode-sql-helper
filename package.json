{
  "name": "vscode-sql-helper",
  "displayName": "SQL Helper",
  "description": "VS Code extension with Vue webview and Rust SQL analyzer.",
  "version": "0.0.1",
  "publisher": "local",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:sqlHelper.openAnalyzer",
    "onCustomEditor:sqlHelper.sqliteViewer",
    "onLanguage:sql"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sqlHelper.openAnalyzer",
        "title": "SQL Helper: Open Analyzer"
      }
    ],
    "customEditors": [
      {
        "viewType": "sqlHelper.sqliteViewer",
        "displayName": "SQL Helper SQLite Viewer",
        "selector": [
          {
            "filenamePattern": "*.sqlite"
          },
          {
            "filenamePattern": "*.sqlite3"
          },
          {
            "filenamePattern": "*.db"
          },
          {
            "filenamePattern": "*.db3"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "clean": "rimraf dist bin",
    "build": "npm run build:rust && npm run build:webview && npm run build:extension",
    "build:extension": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js",
    "build:webview": "vite build --config webview/vite.config.ts",
    "build:rust": "cargo build --manifest-path crates/sql-analyzer/Cargo.toml --release && node scripts/copy-rust-binary.mjs",
    "dev:webview": "vite build --watch --config webview/vite.config.ts",
    "watch:extension": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js --watch",
    "check": "tsc --noEmit",
    "package": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "esbuild": "^0.25.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vue": "^3.5.13"
  }
}
