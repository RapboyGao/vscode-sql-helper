{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run SQL Helper Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "build-extension",
      "presentation": {
        "group": "extension",
        "order": 1
      }
    },
    {
      "name": "Run SQL Helper Extension (No Build)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "presentation": {
        "group": "extension",
        "order": 2
      }
    }
  ]
}
