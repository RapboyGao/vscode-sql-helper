{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Universal SQL Database Manager",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/apps/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/apps/extension/dist/**/*.js"
      ],
      "preLaunchTask": "build-workspace"
    }
  ]
}

